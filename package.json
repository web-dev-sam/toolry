{
  "name": "cliry",
  "version": "0.1.0",
  "description": "A wrapper library around citty and @clack/prompts to create a beautiful devtool cli with no boilerplate.",
  "homepage": "https://github.com/web-dev-sam/cliry#readme",
  "bugs": {
    "url": "https://github.com/web-dev-sam/cliry/issues"
  },
  "license": "MIT",
  "author": "Samuel Braun <sam@webry.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-dev-sam/cliry.git"
  },
  "files": [
    "src",
    "bin"
  ],
  "type": "module",
  "bin": {
    "cliry": "./bin/tools.ts"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "citty": "^0.2.1",
    "colorette": "^2.0.20",
    "tsx": "^4.21.0"
  }
}